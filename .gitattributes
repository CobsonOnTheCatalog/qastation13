# dmm map merger hook
# needs additional setup, see maptools/install.txt
*.dmm merge=merge-dmm
* text=auto

# the most brutal windowspill ever
*.bat text eol=lf
*.cjs text eol=lf
*.css text eol=lf
*.dm text eol=lf
*.dme text eol=lf
*.dmf text eol=lf
*.htm text eol=lf
*.html text eol=lf
